{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":pinAllExceptPeerDependencies",
    "customManagers:biomeVersions"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": ["* 12-17 * * *"],
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "{{manager}} (non-major)",
      "groupSlug": "{{manager}}-non-major",
      "automerge": true
    },
    {
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchUpdateTypes": ["pin", "pinDigest", "digest"],
      "minimumReleaseAge": "0 days",
      "automerge": true
    },
    {
      "matchPackageNames": ["hashicorp/terraform"],
      "groupName": "terraform",
      "groupSlug": "terraform"
    },
    {
      "matchDepNames": ["@biomejs/biome"],
      "groupName": "biome",
      "groupSlug": "biome"
    }
  ],
  "vulnerabilityAlerts": {
    "minimumReleaseAge": "0 days",
    "labels": ["security"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)\\.tflint\\.hcl$/"],
      "matchStrings": [
        "plugin\\s+\"aws\"\\s*\\{[\\s\\S]*?version\\s*=\\s*\"(?<currentValue>[^\"]+)\"[\\s\\S]*?source\\s*=\\s*\"github\\.com/(?<depName>[^\"]+)\""
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^mise\\.toml$/"],
      "matchStrings": ["yamllint==(?<currentValue>[\\d.]+)"],
      "depNameTemplate": "yamllint",
      "datasourceTemplate": "pypi"
    }
  ]
}
